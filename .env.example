# ============================================================
# .env.example — Doblen Solutions x Farmacias del Pueblo
# Copiá este archivo como .env y completá los valores.
# NUNCA subas el .env al repo.
# En Railway, cargá estas variables en el panel de Variables.
# ============================================================

# --- Zetti API ---
ZETTI_BASE_URL=http://farmaciasdelpueblo.com:9080/api-rest
ZETTI_OAUTH_URL=http://farmaciasdelpueblo.com:9080/oauth-server/oauth/token
ZETTI_CLIENT_ID=
ZETTI_CLIENT_SECRET=
ZETTI_USERNAME=
ZETTI_PASSWORD=
ZETTI_NODE_ID=

# --- Gmail (para envío automático) ---
# Cuenta que manda el mail
GMAIL_USER=2blen.solutions@gmail.com
# App Password generada en: myaccount.google.com → Seguridad → Contraseñas de aplicaciones
GMAIL_APP_PASSWORD=
# Destinatarios separados por coma
MAIL_DESTINATARIOS=
